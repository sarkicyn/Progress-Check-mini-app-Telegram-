<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Progress Check</title>
  <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
  <link rel="stylesheet" href="/static/styles.css?v=3">
</head>
<body>
  <div class="device-shell">
    <div class="screen-glow"></div>
    <div class="app-shell">
      <header class="topbar">

        <h1 id="screen-title">Главная</h1>
        
      </header>

      <main class="content">
        <section class="panel active" data-panel="home">
          <div class="hero-row">
         
            <div class="streak-badge"><span id="streak-value">0</span><span class="fire">🔥</span></div>
          </div>

          <button class="action-card primary" id="open-workout-flow" type="button">
            <span>Добавить тренировку</span>
            <span class="plus">+</span>
          </button>

          <section class="note-card">
            <p class="note-label">Поделись своим самочувствием</p>
            <textarea id="wellbeing-note"></textarea>
          </section>
        </section>

        <section class="panel" data-panel="profile">
          <div class="panel-stack">

            <button class="action-card secondary" id="profile-records-link" type="button">
              <span>🏆 Рекорды</span>
              <span>🏆</span>
            </button>
          </div>

          <section class="profile-card">
            <h2>Мои данные</h2>
            <div class="profile-list">
              <div class="profile-line"><span>Имя</span><strong id="profile-name">Пользователь</strong></div>
              <div class="profile-line"><span>Вес</span><strong id="weight-value">—</strong></div>
              <div class="profile-line"><span>Рост</span><strong id="height-value">—</strong></div>
              <div class="profile-line"><span>Стаж</span><strong id="experience-value">—</strong></div>
              <div class="profile-line"><span>Тренировок</span><strong id="workouts-value">0</strong></div>
            </div>
          </section>

          <section class="section-block">
            <div class="section-title"> `
              <h2>История тренировок</h2>
            </div>
            <div id="history-list" class="list-stack"></div>
          </section>
        </section>

        <section class="panel" data-panel="records">
          <div class="records-toolbar">
           
            <button class="round-tool" ><span id="delete-btn"><i class='bx bx-plus-circle'></i></span> </button>
          </div>
          <div id="records-list" class="list-stack"></div>
        </section>

        <section class="panel" data-panel="faq">
          <div class="search-shell">
            <input type="search" id="faq-search" placeholder="Поиск вопросов...">
          </div>
          <div id="faq-tabs" class="chip-row"></div>
          <div id="faq-list" class="list-stack"></div>
        </section>
      </main>

      <nav class="bottom-nav">
        <button class="nav-btn active" data-tab="home" type="button">
          <span class="nav-icon">🏠</span>
          <span class="nav-label">Главная</span>
        </button>
        <button class="nav-btn" data-tab="profile" type="button">
          <span class="nav-icon">🏋️‍♂️</span>
          <span class="nav-label">Профиль</span>
        </button>
        <button class="nav-btn" data-tab="records" type="button">
          <span class="nav-icon">🏆</span>
          <span class="nav-label">Рекорды</span>
        </button>
      </nav>
    </div>
  </div>

  <div class="workout-overlay" id="workout-overlay" hidden>
    <div class="workout-modal">
      <div class="modal-head">
        <button class="icon-btn subtle" id="close-workout-flow" type="button" aria-label="Закрыть"> <i class='bx bxs-left-arrow' ></i> </button>
        <p id="modal-title">Добавить упражнения</p>
        <button class="icon-btn subtle" id="save-workout-flow" type="button" aria-label="Сохранить">✓</button>
      </div>
      <section class="modal-step active" data-step="list">
        <label class="field-card workout-name-card">
          <span class="field-label">Название тренировки</span>
          <input type="text" id="workout-name-input" placeholder="Например: Грудь и трицепс">
        </label>
        <div id="draft-list" class="draft-list"></div>
        <button class="action-card secondary" id="add-draft-item" type="button">
          <span>Добавить упражнение</span>
          <span class="plus">+</span>
        </button>
        <button class="action-card danger" id="delete-workout-day" type="button" hidden>
          <span>Удалить тренировку</span>
          <span class="plus"><i class='bx bx-trash'></i></span>
        </button>
      </section>

      <section class="modal-step" data-step="form">
        <label class="field-card">th
          <span class="field-label">Название упражнения</span>
          <input type="text" id="exercise-name-input" placeholder="Например: Жим лежа">
        </label>
        <div class="metrics-card">
          <div class="metric-big">
            <span class="field-label">Вес (кг)</span>
            <input type="number" id="exercise-weight-input" min="0" step="0.5" placeholder="80">
          </div>
          <div class="counter-line">
            <span>Подходы</span>
            <div class="counter-control">
              <button class="counter-btn" data-counter="sets" data-direction="-1" type="button">−</button>
              <strong id="sets-value">1</strong>
              <button class="counter-btn" data-counter="sets" data-direction="1" type="button">+</button>
            </div>
          </div>
          <div class="counter-line">
            <span>Повторы</span>
            <div class="counter-control">
              <button class="counter-btn" data-counter="reps" data-direction="-1" type="button">−</button>
              <strong id="reps-value">8</strong>
              <button class="counter-btn" data-counter="reps" data-direction="1" type="button">+</button>
            </div>
          </div>
        </div>
        <button class="action-card primary" id="confirm-draft-item" type="button">
          <span>Сохранить упражнение</span>
          <span class="plus"><i class='bx bx-check'></i></span>
        </button>
      </section>

      <section class="modal-step" data-step="date">
        <div class="date-card">
          <p class="field-label">Дата тренировки</p>
          <div class="date-preview" id="date-preview">сегодня</div>
          <input type="date" id="workout-date-input">
        </div>
      </section>

      <section class="modal-step" data-step="done">
        <div class="result-card">
          <h2>Тренировка сохранена</h2>
          <p id="saved-summary">Все упражнения добавлены.</p>
        </div>
      </section>
    </div>
  </div>

  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <script src="/static/app.js?v=3"></script>
</body>
</html>
